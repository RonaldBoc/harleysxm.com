---
import { useTranslations, type Lang } from '../i18n/index';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---

<div class="banner">
  <div class="banner-text">
    <h2>{t.banner.title1}<br />{t.banner.title2}</h2>
    <p>{t.banner.sub}</p>
  </div>

  <div class="banner-badges">
    <div class="badge">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="10" y="16" width="16" height="14" rx="2"/>
        <path d="M12 16 L12 11 C12 7.7 14.7 5 18 5 C21.3 5 24 7.7 24 11 L24 16"/>
        <circle cx="18" cy="23" r="2" fill="white" stroke="none"/>
        <line x1="18" y1="23" x2="18" y2="26" stroke="white" stroke-width="1.5"/>
      </svg>
      <span class="badge-text">{(t.banner.badge1 as string[]).join('\n')}</span>
    </div>

    <div class="badge">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8 C18 8 14 6 10 8 C10 8 8 12 9 16 C10 20 14 24 18 26 C22 24 26 20 27 16 C28 12 26 8 26 8 C22 6 18 8 18 8Z"/>
        <path d="M12 22 C10 24 9 26 9 28"/>
        <path d="M24 22 C26 24 27 26 27 28"/>
        <path d="M8 28 C10 27 13 27 16 28"/>
        <path d="M20 28 C23 27 26 27 28 28"/>
      </svg>
      <span class="badge-text">{(t.banner.badge2 as string[]).join('\n')}</span>
    </div>

    <div class="badge">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 7 L4 22 C4 31 18 37 18 37 C18 37 32 31 32 22 L32 7 Z"/>
        <line x1="8" y1="11"  x2="28" y2="11"  stroke="white" stroke-width="0.7" opacity="0.5"/>
        <line x1="8" y1="15" x2="28" y2="15" stroke="white" stroke-width="0.7" opacity="0.5"/>
        <text x="18" y="28" font-family="'Bebas Neue', sans-serif" font-size="10" fill="white" text-anchor="middle" dominant-baseline="middle" letter-spacing="0.5">HD</text>
      </svg>
      <span class="badge-text">{(t.banner.badge3 as string[]).join('\n')}</span>
    </div>
  </div>
</div>

<style>
  .banner {
    background: var(--hd-orange);
    padding: 56px 80px;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .banner-text h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 50px;
    line-height: 1.05;
    color: white;
    margin-bottom: 10px;
  }
  .banner-text p {
    font-size: 14px;
    color: rgba(255,255,255,0.82);
    font-weight: 300;
    max-width: 360px;
  }

  .banner-badges {
    display: flex;
    flex-direction: row;
    gap: 40px;
  }

  .badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .badge-text {
    font-family: 'Oswald', sans-serif;
    font-size: 11px;
    color: rgba(255,255,255,0.88);
    text-align: center;
    white-space: pre-line;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 1023px) {
    .banner { padding: 56px 48px; gap: 32px; }
  }

  @media (max-width: 767px) {
    .banner { flex-direction: column; padding: 48px 24px; align-items: flex-start; }
    .banner-badges { flex-direction: row; }
  }
</style>
