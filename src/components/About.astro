---
import { useTranslations, type Lang } from '../i18n/index';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---

<section id="about" class="about">
  <div class="about-text">
    <p class="section-label">{t.about.label}</p>
    <h2 class="section-title">
      {t.about.title_line1}<br /><em>{t.about.title_line2}</em>
    </h2>
    <div class="divider"></div>
    <p class="about-p">{t.about.p1}</p>
    <p class="about-p">{t.about.p2}</p>
    <div class="about-stats">
      <div class="stat">
        <span class="stat-num">{t.about.stat1_num}</span>
        <span class="stat-label">{t.about.stat1_label}</span>
      </div>
      <div class="stat">
        <span class="stat-num">{t.about.stat2_num}</span>
        <span class="stat-label">{t.about.stat2_label}</span>
      </div>
      <div class="stat">
        <span class="stat-num">{t.about.stat3_num}</span>
        <span class="stat-label">{t.about.stat3_label}</span>
      </div>
    </div>
  </div>

  <div class="about-image">
    <img
      src="/images/shop-clothes.jpg"
      alt="Harley-Davidson merchandise inside the shop"
      class="about-img"
    />
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.about-text', {
    x: -60, opacity: 0, duration: 1, ease: 'power3.out',
    scrollTrigger: { trigger: '.about', start: 'top 75%' },
  });
  gsap.from('.about-image', {
    x: 60, opacity: 0, duration: 1, ease: 'power3.out',
    scrollTrigger: { trigger: '.about', start: 'top 75%' },
  });
</script>

<style>
  .about {
    background: var(--hd-dark);
    padding: 100px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-p {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(240,236,228,0.72);
    margin-bottom: 20px;
  }

  .about-stats {
    display: flex;
    gap: 44px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: 14px;
    border-left: 3px solid var(--hd-orange);
  }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 50px;
    line-height: 1;
    color: var(--hd-light);
  }
  .stat-label {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hd-muted);
  }

  .about-image {
    position: relative;
  }
  .about-image::before {
    content: '';
    position: absolute;
    top: -16px; left: -16px; right: 16px; bottom: 16px;
    border: 2px solid var(--hd-orange);
    z-index: 0;
  }
  .about-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 500px;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 1023px) {
    .about {
      grid-template-columns: 1fr;
      padding: 80px 48px;
    }
    .about-image { order: 2; }
    .about-text { order: 1; }
  }

  @media (max-width: 767px) {
    .about { padding: 64px 24px; gap: 48px; }
    .about-stats { flex-direction: column; gap: 20px; }
    .about-img { height: 300px; }
  }
</style>
