---
import { useTranslations, type Lang } from '../i18n/index';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---

<footer>
  <div class="footer-logo">
    <span class="logo-harley">HARLEY</span><span class="logo-sxm">SXM</span><span class="logo-com">.COM</span>
  </div>
  <p class="footer-copy">{t.footer.copy}</p>
  <span class="footer-tagline">{t.footer.tagline}</span>
</footer>

<style>
  footer {
    background: var(--hd-black);
    border-top: 1px solid rgba(255,102,0,0.12);
    padding: 38px 80px;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 17px;
    letter-spacing: 0.08em;
  }
  .logo-harley { color: var(--hd-muted); }
  .logo-sxm { color: var(--hd-orange); }
  .logo-com { color: var(--hd-muted); }

  .footer-copy {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    color: rgba(119,119,119,0.55);
    font-weight: 400;
  }

  .footer-tagline {
    font-family: 'Oswald', sans-serif;
    font-size: 11px;
    color: #3a3a3a;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  @media (max-width: 767px) {
    footer {
      flex-direction: column;
      gap: 16px;
      text-align: center;
      padding: 32px 24px;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    footer { padding: 38px 48px; }
  }
</style>
