---
import { useTranslations, type Lang } from '../i18n/index';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---

<section class="hero">
  <img
    src="/images/shop-front.jpg"
    alt="Harley-Davidson FWI shop front at Bobbys Marina"
    class="hero-bg-img"
  />
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <p class="hero-eyebrow">{t.hero.eyebrow}</p>
    <h1>
      HARLEY<span class="accent"> SXM</span>
    </h1>
    <p class="hero-sub">{t.hero.sub}</p>
    <p class="hero-desc">{t.hero.desc}</p>
    <div class="hero-ctas">
      <a href="#products" class="btn-primary">{t.hero.cta_primary}</a>
      <a href="#contact" class="btn-outline">{t.hero.cta_outline}</a>
    </div>
  </div>

  <div class="scroll-hint">
    <span class="scroll-arrow">↓</span>
    <span>{t.hero.scroll_hint}</span>
  </div>

  <div class="hero-diagonal"></div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('.hero-eyebrow', { y: 24, opacity: 0, duration: 0.7 })
    .from('.hero h1',      { y: 40, opacity: 0, duration: 0.8 }, '-=0.4')
    .from('.hero-sub',     { y: 20, opacity: 0, duration: 0.6 }, '-=0.5')
    .from('.hero-desc',    { y: 20, opacity: 0, duration: 0.6 }, '-=0.4')
    .from('.hero-ctas',    { y: 20, opacity: 0, duration: 0.6 }, '-=0.4')
    .from('.scroll-hint',  { opacity: 0, duration: 0.5 },        '-=0.2');

  gsap.to('.hero-bg-img', {
    yPercent: 25,
    ease: 'none',
    scrollTrigger: {
      trigger: '.hero',
      start: 'top top',
      end: 'bottom top',
      scrub: true,
    },
  });
</script>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 680px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(108deg, rgba(10,10,10,0.93) 38%, rgba(10,10,10,0.45) 100%);
    z-index: 1;
  }

  .hero-diagonal {
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    height: 100px;
    background: var(--hd-black);
    clip-path: polygon(0 100%, 100% 0, 100% 100%);
    z-index: 3;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 80px;
    max-width: 860px;
    padding-top: 70px;
  }

  .hero-eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--hd-orange);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 36px;
    height: 2px;
    background: var(--hd-orange);
    flex-shrink: 0;
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(76px, 11vw, 148px);
    line-height: 0.88;
    letter-spacing: 0.03em;
    color: var(--hd-light);
    margin-bottom: 20px;
  }
  h1 .accent { color: var(--hd-orange); }

  .hero-sub {
    font-family: 'Oswald', sans-serif;
    font-weight: 400;
    font-size: 26px;
    letter-spacing: 0.28em;
    color: var(--hd-muted);
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .hero-desc {
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: 15px;
    max-width: 460px;
    line-height: 1.8;
    color: rgba(240,236,228,0.72);
    margin-bottom: 36px;
  }

  .hero-ctas {
    display: flex;
    flex-direction: row;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    background: var(--hd-orange);
    padding: 15px 38px;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #e05800; }

  .btn-outline {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--hd-light);
    background: transparent;
    border: 1px solid rgba(240,236,228,0.25);
    padding: 15px 38px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: var(--hd-orange); color: var(--hd-orange); }

  .scroll-hint {
    position: absolute;
    bottom: 40px;
    left: 80px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Oswald', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hd-muted);
  }
  .scroll-arrow { font-size: 14px; }

  @media (max-width: 767px) {
    .hero-content { padding: 0 24px; padding-top: 70px; }
    h1 { font-size: 72px; }
    .scroll-hint { display: none; }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-content { padding: 0 48px; padding-top: 70px; }
    .scroll-hint { left: 48px; }
  }
</style>
