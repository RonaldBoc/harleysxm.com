---
import { useTranslations, type Lang } from '../i18n/index';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---

<nav id="main-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <svg width="32" height="40" viewBox="0 0 32 40" fill="none">
        <path d="M4 3 L4 22 C4 33 16 39 16 39 C16 39 28 33 28 22 L28 3 Z" fill="none" stroke="#FF6600" stroke-width="1.5"/>
        <line x1="8" y1="8"  x2="24" y2="8"  stroke="#FF6600" stroke-width="0.6" opacity="0.5"/>
        <line x1="8" y1="12" x2="24" y2="12" stroke="#FF6600" stroke-width="0.6" opacity="0.5"/>
        <text x="16" y="26" font-family="'Bebas Neue', sans-serif" font-size="12" fill="#FF6600" text-anchor="middle" dominant-baseline="middle" letter-spacing="0.5">HD</text>
      </svg>
      <span class="nav-logo-text"><span class="logo-harley">HARLEY</span><span class="logo-sxm">SXM</span></span>
    </a>

    <div class="nav-right">
      <ul class="nav-links">
        <li><a href="#about">{t.nav.about}</a></li>
        <li><a href="#products">{t.nav.shop}</a></li>
        <li><a href="#contact">{t.nav.find}</a></li>
      </ul>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu">
        <svg width="22" height="16" viewBox="0 0 22 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <line x1="0" y1="2"  x2="22" y2="2"/>
          <line x1="0" y1="8"  x2="22" y2="8"/>
          <line x1="0" y1="14" x2="22" y2="14"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    <ul>
      <li><a href="#about">{t.nav.about}</a></li>
      <li><a href="#products">{t.nav.shop}</a></li>
      <li><a href="#contact">{t.nav.find}</a></li>
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 10);
  });

  hamburger.addEventListener('click', () => {
    nav.classList.toggle('menu-open');
  });

  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.remove('menu-open');
    });
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 70px;
    background: rgba(10,10,10,0.94);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255,102,0,0.18);
    z-index: 1000;
    transition: border-color 0.3s;
  }
  nav.scrolled { border-bottom-color: rgba(255,102,0,0.4); }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    padding: 0 80px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  .nav-logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 21px;
    letter-spacing: 0.08em;
    display: flex;
    gap: 6px;
  }
  .logo-harley { color: var(--hd-light); }
  .logo-sxm { color: var(--hd-orange); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 32px;
  }
  .nav-links a {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--hd-light);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s, color 0.2s;
  }
  .nav-links a:hover { opacity: 1; color: var(--hd-orange); }

  .hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--hd-light);
    cursor: pointer;
    padding: 4px;
  }

  .mobile-menu {
    display: none;
    background: rgba(10,10,10,0.98);
    border-top: 1px solid rgba(255,102,0,0.15);
    padding: 24px 24px 28px;
  }
  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .mobile-menu ul a {
    font-family: 'Oswald', sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--hd-light);
    text-decoration: none;
    opacity: 0.8;
    transition: color 0.2s, opacity 0.2s;
  }
  .mobile-menu ul a:hover { color: var(--hd-orange); opacity: 1; }
  .mobile-lang {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  nav.menu-open .mobile-menu { display: block; }

  @media (max-width: 767px) {
    .nav-inner { padding: 0 24px; }
    .nav-links { display: none; }
    .hamburger { display: block; }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .nav-inner { padding: 0 48px; }
  }
</style>
